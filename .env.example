# Required Telegram bot token from @BotFather.
BOT_TOKEN=replace-me

# Persistent SQLite database inside the production container volume.
DATABASE_URL=sqlite+aiosqlite:////app/data/newstock_alert_bot.sqlite3

# Stock scheduler and runtime tuning.
STOCK_CHECK_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
PLAYWRIGHT_TIMEOUT=30
MAX_CONCURRENT_CHECKS=2

# Optional settings.
APP_ENV=production
SCHEDULER_TIMEZONE=Asia/Kolkata
BROWSER_HEADLESS=true
