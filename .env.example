APP_ENV=development
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=replace-me
DATABASE_URL=sqlite+aiosqlite:///./data/newstock_alert_bot.sqlite3
SCHEDULER_TIMEZONE=Asia/Kolkata
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_SECONDS=30
STOCK_CHECK_INTERVAL_SECONDS=300
BROWSER_POOL_SIZE=2
BROWSER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
AMAZON_MIN_DELAY_MS=250
AMAZON_MAX_DELAY_MS=1500
AMAZON_RETRY_BACKOFF_SECONDS=0.75
STOCK_CHECK_WORKER_LIMIT=2
STOCK_CHECK_RETRY_ATTEMPTS=2
