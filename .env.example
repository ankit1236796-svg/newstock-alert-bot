# Required: Telegram bot token from BotFather.
BOT_TOKEN=

# Runtime environment.
APP_ENV=production
LOG_LEVEL=INFO

# Persistent SQLite database inside the Docker volume.
DATABASE_URL=sqlite+aiosqlite:////app/data/newstock_alert_bot.sqlite3

# Scheduler.
SCHEDULER_TIMEZONE=Asia/Kolkata
STOCK_CHECK_INTERVAL_SECONDS=300
STOCK_CHECK_WORKER_LIMIT=2
MAX_CONCURRENT_CHECKS=2
STOCK_CHECK_RETRY_ATTEMPTS=2

# Browser / Playwright.
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_SECONDS=30
PLAYWRIGHT_TIMEOUT=30
BROWSER_POOL_SIZE=2
BROWSER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# Amazon adapter throttling and retry defaults.
AMAZON_MIN_DELAY_MS=250
AMAZON_MAX_DELAY_MS=1500
AMAZON_RETRY_BACKOFF_SECONDS=0.75
